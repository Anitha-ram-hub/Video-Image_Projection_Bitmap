// ====================================================

void setup() {

  Serial.begin(115200);

  if (!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {

    Serial.println("SSD1306 allocation failed");

    while (true);

  }

  display.clearDisplay();
  display.display();
}



// ====================================================
// MAIN LOOP
// ====================================================

void loop() {

  introScene();

  doraStanding();

  missionScene();

  walkingScene();

  forestScene();

  forestText();

  unicornFound();

  finalScene();
}



